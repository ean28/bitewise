<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.bitewise.app.feature.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home_screen" >
        <action
            android:id="@+id/action_nav_home_to_nav_product_detail"
            app:destination="@id/nav_product_detail" />
        <action
            android:id="@+id/action_nav_home_to_nav_ai_sync"
            app:destination="@id/nav_ai_sync" />
    </fragment>

    <fragment
        android:id="@+id/nav_search"
        android:name="com.bitewise.app.feature.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search_screen" >
        <action
            android:id="@+id/action_nav_search_to_productDetailFragment"
            app:destination="@id/nav_product_detail" />
    </fragment>

    <fragment
        android:id="@+id/nav_product_detail"
        android:name="com.bitewise.app.feature.product.ui.ProductDetailFragment"
        android:label="Product Details"
        tools:layout="@layout/fragment_product_information">
        <argument
            android:name="arg_barcode"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.bitewise.app.feature.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" >
        <action
            android:id="@+id/action_nav_settings_to_nav_database_inspector"
            app:destination="@id/nav_database_inspector" />
    </fragment>

    <fragment
        android:id="@+id/nav_database_inspector"
        android:name="com.bitewise.app.feature.settings.ui.DatabaseInspectorFragment"
        android:label="Database Inspector"
        tools:layout="@layout/fragment_database_inspector" />

    <fragment
        android:id="@+id/nav_ai_sync"
        android:name="com.bitewise.app.feature.ai.AiSyncFragment"
        android:label="Safety Shield Sync"
        tools:layout="@layout/fragment_ai_sync" />

</navigation>
