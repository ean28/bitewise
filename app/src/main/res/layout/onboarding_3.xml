<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textColor="#BDBDBD"
            android:padding="8dp"
            android:fontFamily="@font/inter_medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Health Profile"
            android:textColor="#212121"
            android:textSize="18sp"
            android:gravity="center"
            android:fontFamily="@font/inter_bold"
            app:layout_constraintTop_toBottomOf="@id/btn_skip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:id="@+id/container_inputs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- MEDICAL CONDITIONS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical Conditions"
                android:fontFamily="@font/inter_bold"
                android:textColor="#212121"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <MultiAutoCompleteTextView
                android:id="@+id/multi_conditions"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Enter"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                android:textColorHint="#D3D3D3"
                android:completionThreshold="1"
                android:importantForAutofill="no"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_conditions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txt_no_conditions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• No Medical Conditions"
                android:textSize="10sp"
                android:textColor="#BDBDBD"
                android:textStyle="italic"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- ALLERGIES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allergies"
                android:fontFamily="@font/inter_bold"
                android:textColor="#212121"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <MultiAutoCompleteTextView
                android:id="@+id/multi_allergies"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Enter"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                android:textColorHint="#D3D3D3"
                android:completionThreshold="1"
                android:importantForAutofill="no"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_allergies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txt_no_allergies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• No Allergies"
                android:textSize="10sp"
                android:textColor="#BDBDBD"
                android:textStyle="italic"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- DIETARY PREFERENCES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dietary Preferences"
                android:fontFamily="@font/inter_bold"
                android:textColor="#212121"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <MultiAutoCompleteTextView
                android:id="@+id/multi_diet"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Enter"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                android:textColorHint="#D3D3D3"
                android:completionThreshold="1"
                android:importantForAutofill="no"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_diet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/txt_no_diet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• None Preferred"
                android:textSize="10sp"
                android:textColor="#BDBDBD"
                android:textStyle="italic"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Next"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="@font/inter_bold"
            android:textColor="@android:color/white"
            app:backgroundTint="#66BB6A"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/container_inputs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>