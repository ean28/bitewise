<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go back"
            android:padding="8dp"
            android:src="?attr/homeAsUpIndicator" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Sync"
            android:textSize="24sp"
            android:fontFamily="@font/inter_bold"
            android:layout_marginStart="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_cache"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear Cache"
            android:textColor="#E53935"
            app:icon="@drawable/ic_safety_shield"
            app:iconTint="#E53935" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_debug_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFCDD2"
        app:cardBackgroundColor="#FFEBEE"
        android:visibility="gone"
        tools:visibility="visible"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧 Sync Debugger"
                android:fontFamily="@font/inter_bold"
                android:textColor="#C62828"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/txt_debug_reason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason: Profile Incomplete"
                android:textSize="12sp"
                android:textColor="#C62828"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_resume_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#BBDEFB"
        app:cardBackgroundColor="#E3F2FD"
        android:visibility="gone"
        tools:visibility="visible"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resume Interrupted Sync?"
                android:fontFamily="@font/inter_bold"
                android:textColor="#1976D2"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A previous sync operation was interrupted. You can resume from where it left off or discard the progress."
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:layout_marginTop="4dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="12dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_resume"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discard Progress"
                    android:textColor="#1976D2" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_resume_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resume Sync"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_resume" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        app:cardElevation="0dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync Configuration"
                android:fontFamily="@font/inter_bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txt_batch_size_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Batch Size: 80"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_batch_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="80.0"
                android:valueTo="150.0"
                android:stepSize="10.0"
                android:value="100.0"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txt_quick_sync_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Sync Limit: 10"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_quick_sync_limit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="5.0"
                android:valueTo="15.0"
                android:stepSize="1.0"
                android:value="10.0"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        app:cardElevation="0dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pre-Flight Status"
                android:fontFamily="@font/inter_bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fresh Analyses:" />
                <TextView
                    android:id="@+id/txt_fresh_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:fontFamily="@font/inter_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stale Items (Need Sync):" />
                <TextView
                    android:id="@+id/txt_stale_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#E53935"
                    android:fontFamily="@font/inter_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estimated Token Usage:" />
                <TextView
                    android:id="@+id/txt_est_tokens"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~0"
                    android:fontFamily="monospace" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quick_sync"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Quick Sync"
            android:layout_marginEnd="8dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_sync"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Full Sync"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/txt_progress_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Syncing: 0/10"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_sync"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop Sync"
                android:textColor="#E53935"
                android:padding="0dp"
                app:icon="@drawable/ic_close"
                app:iconTint="#E53935" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sync &amp; Cost History"
        android:fontFamily="@font/inter_bold"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_sync_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_sync_log" />

</LinearLayout>
