<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txt_barcode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Barcode: 12345678"
            android:fontFamily="@font/inter_bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txt_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score: 85.0"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txt_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Summary goes here..."
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txt_tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tags: Tag1, Tag2"
            android:textSize="10sp"
            android:textColor="#777"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txt_hash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Context Hash: 12345"
            android:textSize="10sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="#999"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
