<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txt_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BiteWise"
        android:textSize="25sp"
        android:fontFamily="@font/inter_bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <!-- add icon,  constraint to end -->


    <!-- User stats -->
    <LinearLayout
        android:id="@+id/container_user_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/rounded_top_container"

        app:layout_constraintTop_toBottomOf="@id/txt_app_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- stats items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textSize="18sp"
                android:text="Status:"
                android:layout_marginStart="20dp"
                android:textColor="@color/white"
                />
        </LinearLayout>

        <!-- item 2-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txt_suggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:textSize="18sp"
                android:text="Suggestion:"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                />
        </LinearLayout>


    </LinearLayout>


    <!-- Horizontal section title -->
    <TextView
        android:id="@+id/txt_recently_viewed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recently Viewed"
        android:textSize="16sp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"

        app:layout_constraintTop_toBottomOf="@id/container_user_stats"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Horizontal scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recently_viewed"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginStart="15dp"

        app:layout_constraintTop_toBottomOf="@id/txt_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    </androidx.recyclerview.widget.RecyclerView>


    <!-- Vertical section title -->
    <TextView
        android:id="@+id/txt_recommendations"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommendations"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="16dp"

        app:layout_constraintTop_toBottomOf="@id/recycler_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Vertical scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/container_vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"

        app:layout_constraintTop_toBottomOf="@id/txt_recommendations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- vertical items -->

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>