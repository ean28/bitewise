<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txt_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BiteWise"
        android:textSize="26sp"
        android:fontFamily="@font/inter_bold"
        android:layout_marginStart="25dp"
        android:layout_marginTop="15dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <Button
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_user"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="10dp"
        app:backgroundTint="@color/dark"

        app:layout_constraintTop_toTopOf="@id/txt_app_title"
        app:layout_constraintBottom_toBottomOf="@id/txt_app_title"
        app:layout_constraintEnd_toEndOf="@+id/container_user_stats"
        />

    <!-- User stats -->
    <LinearLayout
        android:id="@+id/container_user_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/rounded_top_container"

        app:layout_constraintTop_toBottomOf="@id/txt_app_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 1. Status Label -->
            <TextView
                android:id="@+id/txt_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textColor="@color/white"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="@id/txt_suggestion" />

            <!-- 2. Status Content -->
            <TextView
                android:id="@+id/txt_status_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="15dp"
                app:layout_constraintStart_toEndOf="@id/txt_suggestion"
                app:layout_constraintTop_toTopOf="@id/txt_status" />

            <!-- 3. Suggestion Label (Below Status) -->
            <TextView
                android:id="@+id/txt_suggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suggestion:"
                android:textColor="@color/white"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_status"
                android:layout_marginTop="10dp" />

            <!-- 4. Suggestion Content -->
            <TextView
                android:id="@+id/txt_suggestion_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No suggestions yet"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="15dp"
                app:layout_constraintStart_toEndOf="@id/txt_suggestion"
                app:layout_constraintTop_toTopOf="@id/txt_suggestion" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>


    <!-- Horizontal section title -->
    <TextView
        android:id="@+id/txt_recently_viewed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recently Viewed"
        android:textSize="16sp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"

        app:layout_constraintTop_toBottomOf="@id/container_user_stats"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Horizontal scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recently_viewed"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginStart="15dp"

        app:layout_constraintTop_toBottomOf="@id/txt_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    </androidx.recyclerview.widget.RecyclerView>


    <!-- Vertical section title -->
    <TextView
        android:id="@+id/txt_recommendations"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommendations"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginTop="16dp"

        app:layout_constraintTop_toBottomOf="@id/recycler_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"/>


    <!-- Vertical scroll -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/container_vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"

        app:layout_constraintTop_toBottomOf="@id/txt_recommendations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- vertical items -->

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>