<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/txt_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BiteWise"
        android:textSize="26sp"
        android:fontFamily="@font/inter_bold"
        android:layout_marginStart="25dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_safety_status"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:icon="@drawable/ic_safety_shield"
        app:iconTint="@color/green_status"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- User stats -->
    <LinearLayout
        android:id="@+id/container_user_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/rounded_top_container"
        app:layout_constraintTop_toBottomOf="@id/txt_app_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 1. Status Label -->
            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textColor="@color/white"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- 2. Status Content -->
            <TextView
                android:id="@+id/txt_status_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="15dp"
                app:layout_constraintStart_toEndOf="@id/txt_status"
                app:layout_constraintTop_toTopOf="@id/txt_status" />

            <!-- 3. Suggestion Label (Below Status) -->
            <TextView
                android:id="@+id/txt_suggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suggestion:"
                android:textColor="@color/white"
                android:fontFamily="@font/inter_medium"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_status"
                android:layout_marginTop="10dp" />

            <!-- 4. Suggestion Content -->
            <TextView
                android:id="@+id/txt_suggestion_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No suggestions yet"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginStart="15dp"
                app:layout_constraintStart_toEndOf="@id/txt_suggestion"
                app:layout_constraintTop_toTopOf="@id/txt_suggestion" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Horizontal section title -->
    <TextView
        android:id="@+id/txt_recently_viewed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recently Viewed"
        android:textSize="16sp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/container_user_stats"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Horizontal scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recently_viewed"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginStart="15dp"
        app:layout_constraintTop_toBottomOf="@id/txt_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/home_item_tile_horizontal" />

    <!-- Vertical section title -->
    <TextView
        android:id="@+id/txt_recommendations"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recommendations"
        android:textSize="16sp"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_medium"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/recycler_recently_viewed"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txt_recommendation_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:fontFamily="@font/inter_medium"
        android:textColor="#757575"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="@id/txt_recommendations"
        app:layout_constraintTop_toTopOf="@id/txt_recommendations"
        app:layout_constraintStart_toEndOf="@id/txt_recommendations"
        tools:text="(12 items)"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_recommendation_sync"
        style="@style/Widget.Material3.Button.TextButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sync AI"
        android:textSize="12sp"
        app:icon="@drawable/ic_safety_shield"
        app:iconSize="16dp"
        app:iconTint="@color/green_status"
        android:textColor="@color/green_status"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/txt_recommendations"
        app:layout_constraintTop_toTopOf="@id/txt_recommendations"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="8dp"/>

    <!-- Recommendations RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recommendations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txt_recommendations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/home_item_tile_vertical" />

    <!-- Sync Prompt Overlay -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_sync_prompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/txt_recommendations"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="#F9F9F9">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_safety_shield"
                app:tint="@color/green_status" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unlock Personalized Safety"
                android:textSize="20sp"
                android:fontFamily="@font/inter_bold"
                android:layout_marginTop="16dp"
                android:textAlignment="center"
                android:textColor="#212121"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get tailored product recommendations based on your dietary needs with AI-powered verification."
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textAlignment="center"
                android:alpha="0.7"
                android:textColor="#424242"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_not_now"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Now"
                    android:textColor="#757575"
                    android:layout_marginEnd="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sync_now"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sync Now"
                    app:cornerRadius="24dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
