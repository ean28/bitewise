<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="110dp"
    android:layout_height="140dp"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_marginEnd="12dp"
    android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/img_search_tile"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:scaleType="centerCrop"/>

    <!-- wrap height temporarily to fix padding of text-->
    <TextView
        android:id="@+id/txt_search_tile_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Food test test tester asdasd"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:textStyle="bold"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/lbl_search_nutriscore"
            android:layout_width="24dp"
            android:layout_height="14dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/grade_nutriscore_none"
            android:contentDescription="nutri_score"/>

        <ImageView
            android:id="@+id/lbl_search_novascore"
            android:layout_width="10dp"
            android:layout_height="15dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/grade_novagroup_none"
            android:contentDescription="nova_group" />

        <ImageView
            android:id="@+id/lbl_search_greenscore"
            android:layout_width="24dp"
            android:layout_height="14dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/grade_greenscore_none"
            android:contentDescription="eco_score" />

    </LinearLayout> </LinearLayout>