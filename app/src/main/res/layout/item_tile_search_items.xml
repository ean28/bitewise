<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp"
    android:layout_marginBottom="5dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_search_tile"
            android:layout_width="113dp"
            android:layout_height="110dp"
            app:shapeAppearanceOverlay="@style/RoundedSquare"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_ai_score"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#F5F5F5"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-10dp"
            android:layout_marginEnd="-10dp">

            <TextView
                android:id="@+id/txt_ai_score_value"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                tools:text="85"
                android:textSize="12sp"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/green_status"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txt_search_tile_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="10sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            tools:ignore="SmallSp"
            app:layout_constraintTop_toBottomOf="@id/img_search_tile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Food test test tester" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/txt_search_tile_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/lbl_search_nutriscore"
                android:layout_width="24dp"
                android:layout_height="14dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/grade_nutriscore_none"
                android:contentDescription="nutri_score"/>

            <ImageView
                android:id="@+id/lbl_search_novascore"
                android:layout_width="8dp"
                android:layout_height="13dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/grade_novagroup_none"
                android:contentDescription="nova_group" />

            <ImageView
                android:id="@+id/lbl_search_greenscore"
                android:layout_width="24dp"
                android:layout_height="14dp"
                android:src="@drawable/grade_greenscore_none"
                android:contentDescription="eco_score" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
